<odoo>
    <record id='clinic_visit_sequence' model='ir.sequence'>
        <field name='name'>clinic_visit_sequence</field>
        <field name='code'>clinic_visit_seq</field>
        <field name='prefix'>VIS/%(year)s/%(month)s/</field>
        <field name='padding'>4</field>
        <field name='use_date_range'>True</field>
    </record>
</odoo>