<odoo>

    <record id='clinic_appointment_list_view' model='ir.ui.view'>
        <field name='name'>Appointment List View</field>
        <field name='model'>clinic.appointment</field>
        <field name='arch' type='xml'>
            <tree>
                <field name='appointment_no' />
                <field name='patient_id' />
                <field name='doctor_id' />
                <field name='appointment_date' />
                <field name='appointment_hour' />
                <field name='state' />
            </tree>
        </field>
    </record>

    <record id='clinic_appointment_search_view' model='ir.ui.view'>
        <field name='name'>Appointment Search View</field>
        <field name='model'>clinic.appointment</field>
        <field name='arch' type='xml'>
            <search>
                <field name='appointment_no' />
                <field name='patient_id' />
                <field name='doctor_id' />

                <filter name='today' string='Today'
                    domain='[("appointment_date", "=", context_today())]' />
                <filter name='upcoming' string='Upcoming'
                    domain='[("appointment_date", ">=", context_today())]' />
                <filter name='past' string='Past'
                    domain='[("appointment_date", "&lt;", context_today())]' />

                <filter name='group_by_state' string='Group By State'
                    context='{"group_by" : "state"}' />
                <filter name='group_by_doctor' string='Group By Doctor'
                    context='{"group_by" : "doctor_id"}' />
            </search>
        </field>
    </record>

    <record id='clinic_appointment_form_view' model='ir.ui.view'>
        <field name='name'> Appointment Form View</field>
        <field name='model'>clinic.appointment</field>
        <field name='arch' type='xml'>
            <form>
                <header>
                    <button
                        name='mark_as_draft'
                        type='object'
                        string='Reset to Draft'
                        class='btn-primary'
                        invisible='state != "confirmed"'
                    />
                    <button
                        name='mark_as_confirmed'
                        type='object'
                        string='Confirm'
                        class='btn-primary'
                        invisible='state != "draft"'
                    />
                    <button
                        name='mark_as_in_progress'
                        type='object'
                        string='Start Visit'
                        class='btn-primary'
                        invisible='state != "confirmed"'
                    />
                    <button
                        name='mark_as_done'
                        type='object'
                        string='Done'
                        class='btn-primary'
                        invisible='state != "in_progress"'
                    />


                    <field name='state' widget='statusbar' />
                </header>
                <sheet>
                    <h5>
                        <label for='appointment_no' />
                    </h5>
                    <h3>
                        <field name='appointment_no' />
                    </h3>
                    <group>
                        <group>
                            <field name='patient_id' readonly='state != "draft" and appointment_no != "New" or state == "cancelled"'/>
                            <field name='doctor_id' readonly='state != "draft" and appointment_no != "New"'/>
                        </group>
                        <group>
                            <field name='appointment_date' readonly='state != "draft" and appointment_no != "New" or state == "cancelled"'/>
                            <field name='appointment_hour' readonly='state != "draft" and appointment_no != "New" or state == "cancelled"'/>
                        </group>
                        <group>
                            <field name='reason' readonly='state != "draft" and appointment_no != "New" or state == "cancelled"'/>
                        </group>
                        <group>

                            <field name='notes' readonly='state == "cancelled"'/>
                        </group>
                    </group>
                </sheet>
                <div class='oe_chatter'>
                    <field name='message_follower_ids' />
                    <field name='activity_ids' />
                    <field name='message_ids' />
                </div>
            </form>
        </field>
    </record>

    <record id='server_action_clinic_appointment' model='ir.actions.server'>
        <field name='name'>Cancel Appointment</field>
        <field name='model_id' ref='model_clinic_appointment'/>
        <field name='binding_model_id' ref='model_clinic_appointment'/>
        <field name='state'>code</field>
        <field name='code'>
            action = records.mark_as_cancelled()
        </field>
    </record>

    <record id='action_clinic_appointment' model='ir.actions.act_window'>
        <field name='name'>Appointments</field>
        <field name='res_model'>clinic.appointment</field>
    </record>

    <menuitem
        id='clinic_appointment_menu'
        name='Appointments'
        parent='clinic_root_menu'
        action='action_clinic_appointment'
    />
</odoo>